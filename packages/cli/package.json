{
  "name": "forgeclaw",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "forgeclaw": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --compile",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:refine": "bun test tests/refine-"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@forgeclaw/core": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
