{
  "name": "@forgeclaw/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@forgeclaw/core": "workspace:*",
    "grammy": "^1.38.0",
    "@grammyjs/runner": "^2.0.0",
    "@grammyjs/auto-retry": "^2.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.0"
  }
}
