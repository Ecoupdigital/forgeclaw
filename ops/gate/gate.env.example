# Copie este arquivo para gate.env (ou para ~/.forgeclaw/gate.env) e preencha.
# Nao commite gate.env (ja esta no .gitignore).

# GitHub PAT com escopo 'repo' (ou fine-grained scopado a Ecoupdigital/forgeclaw com
# permissao de 'Administration: Read and Write' para poder adicionar/remover collaborators).
GITHUB_TOKEN=github_pat_XXXXXXXXXXXXXXXXXXXXXXXX

# Owner/repo do ForgeClaw. Default: Ecoupdigital/forgeclaw.
REPO_OWNER=Ecoupdigital
REPO_NAME=forgeclaw

# Permissao concedida aos novos collaborators. Para o gate v1 e sempre 'pull' (read-only).
# Valores aceitos pela API do GitHub: pull | triage | push | maintain | admin.
DEFAULT_PERMISSION=pull
